{{- /*gotype: github.com/ogen-go/ogen/gen/ir.Type*/ -}}
{{- define "schema/sum" }}
// {{ $.Name }} represents sum type.
type {{ $.Name }} struct {
	Type {{ $.Name }}Type // switch on this field
	{{- range $s := $.SumOf }}
		{{ $s.Name }} {{ $s.Go }}
	{{- end }}
}

// {{ $.Name }}Type is oneOf type of {{ $.Name }}.
type {{ $.Name }}Type string

// Possible values for {{ $.Name }}Type.
const (
	{{- range $s := $.SumOf }}
	{{- $values := $.SumSpec.GetAllDiscriminatorValues $s }}
	{{- if gt (len $values) 0 }}
	{{- /* Generate constants for discriminator values */}}
	{{- range $key := $values }}
	{{- $mapValue := $.SumSpec.GetMapValue $s $key }}
	{{ $.Name }}{{ $mapValue.FormattedName }} {{ $.Name }}Type = {{ $mapValue.ValueGo }}
	{{- end }}
	{{- else }}
	{{- /* Fallback to type name if no discriminator values */}}
	{{ $s.Name }}{{ $.Name }} {{ $.Name }}Type = "{{ $s.Go }}"
	{{- end }}
	{{- end }}
)

{{- range $s := $.SumOf }}
// Is{{ $s.Name }} reports whether {{ $.Name }} is {{ $s.Go }}.
func (s {{ $.ReadOnlyReceiver }}) Is{{ $s.Name }}() bool {
	switch s.Type {
	{{- $values := $.SumSpec.GetAllDiscriminatorValues $s }}
	{{- if gt (len $values) 0 }}
	{{- range $key := $values }}
	{{- $mapValue := $.SumSpec.GetMapValue $s $key }}
	case {{ $.Name }}{{ $mapValue.FormattedName }}:
		return true
	{{- end }}
	{{- else }}
	{{- /* Using type name directly without GetMapValue */}}
	case {{ $s.Name }}{{ $.Name }}:
		return true
	{{- end }}
	default:
		return false
	}
}
{{- end }}

{{- range $s := $.SumOf }}
// Set{{ $s.Name }} sets {{ $.Name }} to {{ $s.Go }}.
func (s *{{ $.Go }}) Set{{ $s.Name }}(v {{ $s.Go }}) {
	{{- $values := $.SumSpec.GetAllDiscriminatorValues $s }}
	{{- if gt (len $values) 0 }}
	{{- $mapValue := $.SumSpec.GetMapValue $s (index $values 0) }}
	s.Type = {{ $.Name }}{{ $mapValue.FormattedName }}
	{{- else }}
	{{- /* Using type name as fallback when no discriminator value exists */}}
	s.Type = {{ $s.Name }}{{ $.Name }}
	{{- end }}
	s.{{ $s.Name }} = v
}

// Set{{ $s.Name }}WithType sets {{ $.Name }} to {{ $s.Go }} with a specific discriminator value.
func (s *{{ $.Go }}) Set{{ $s.Name }}WithType(v {{ $s.Go }}, discriminator {{ $.Name }}Type) {
	s.Type = discriminator
	s.{{ $s.Name }} = v
}

// Get{{ $s.Name }} returns {{ $s.Go }} and true boolean if {{ $.Go }} is {{ $s.Go }}.
func (s {{ $.ReadOnlyReceiver }}) Get{{ $s.Name }}()(v {{ $s.Go }}, ok bool) {
	if !s.Is{{ $s.Name }}() {
		return v, false
	}
	return s.{{ $s.Name }}, true
}

// New{{ $s.Name }}{{ $.Name }} returns new {{ $.Go }} from {{ $s.Go }}.
func New{{ $s.Name }}{{ $.Name }}(v {{ $s.Go }}) {{ $.Go }} {
	var s {{ $.Name }}
	s.Set{{ $s.Name }}(v)
	return s
}
{{- end }}


{{ end }}

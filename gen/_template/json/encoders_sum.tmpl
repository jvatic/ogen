{{- /*gotype: github.com/ogen-go/ogen/gen/ir.Type*/ -}}
{{- define "json/encoders_sum" }}{{ $d := $.JSON.Sum -}}
// Encode encodes {{ $.Name }} as json.
func (s {{ $.ReadOnlyReceiver }}) Encode(e *jx.Encoder) {
	{{- if $d.Discriminator -}}
	e.ObjStart()
	s.encodeFields(e)
	e.ObjEnd()
	{{- else }}
	if false {
		// Just a placeholder for first condition
	{{- range $s := $.SumOf }}
	} else if s.Is{{ $s.Name }}() {
		{{- template "json/enc" elem $s (printf "s.%s" $s.Name) -}}
	{{- end }}
	} else {
		// Default case - should not happen with valid data
		e.Null()
	}
    {{- end }}
}

{{ if or $d.Discriminator $d.Fields -}}
func (s {{ $.ReadOnlyReceiver }}) encodeFields(e *jx.Encoder) {
	{{- if $d.Discriminator -}}
		// Use the actual discriminator value from s.Type
		e.FieldStart({{ quote $.SumSpec.Discriminator }})
		e.Str(string(s.Type))

		// Then encode the appropriate fields based on which type it is
		if false {
			// Just a placeholder for first condition
		{{- range $s := $.SumOf }}
		} else if s.Is{{ $s.Name }}() {
			{{- $j := $s.JSON.Except $.SumSpec.Discriminator }}
			{{- if $j.AnyFields }}
			{
				s := s.{{ $s.Name }}
				{{- template "json/encode_struct_fields" $j }}
			}
			{{- end }}
		{{- end }}
		}
	{{- else if $d.Fields }}
		if false {
			// Just a placeholder for first condition
		{{- range $s := $.SumOf }}
		} else if s.Is{{ $s.Name }}() {
			{{- template "json/enc" elem $s (printf "s.%s" $s.Name) -}}
		{{- end }}
		} else {
			// Default case - should not happen with valid data
			e.Null()
		}
	{{- else }}
		{{ errorf "unexpected sum type %s" $d }}
	{{- end }}
}
{{- end }}

// Decode decodes {{ $.Name }} from json.
func (s *{{ $.Name }}) Decode(d *jx.Decoder) error {
	if s == nil {
		return errors.New({{ printf "invalid: unable to decode %s to nil" $.Name | quote }})
	}
	// Sum type {{ $d }}.
	{{- if ($d.UniqueObjPropertyNamesDescriminator) }}
	switch t := d.Next(); t {
	case jx.Object:
		{{- $cse := $.UniqueObjPropertyNamesDescriminator }}
		type Decodable interface {
			Decode(*jx.Decoder) error
		}
		var typ {{ $.Name }}Type
		var obj Decodable
		var found bool
		var ErrFound error = errors.New("obj found")
		{{- if ne $cse.Default nil }}
			{{- $s := $cse.Default.Type }}
			typ = {{ $s.Name }}{{ $.Name }} // default case
            obj = &{{- printf "s.%s" $s.Name }} // default case
            found = true // default case
		{{- end }}
		if err := d.Capture(func(d *jx.Decoder) error {
			if err := d.ObjBytes(func(d *jx.Decoder, key []byte) error {
				if err := d.Skip(); err != nil {
					return err
				}
				switch string(key) {
				{{- range $cse := $cse.Cases }}
					{{- $s := $cse.Type }}
                	case {{ $cse.CaseStmtBody }}:
						typ = {{ $s.Name }}{{ $.Name }}
                        obj = &{{- printf "s.%s" $s.Name }}
                        found = true
                        return ErrFound
	            {{- end }}
				}
				return nil
			}); err != nil {
				return err
			}
			return nil
		}); err != nil && errors.Unwrap(err) != ErrFound {
			return err
		}
		if found {
			if err := obj.Decode(d); err != nil {
				return err
			}
			s.Type = typ
		} else {
			return errors.Errorf("unexpected json")
		}
	default:
		return errors.Errorf("unexpected json type %q", t)
	}
	{{- else if or ($d.Primitive) ($d.TypeDiscriminator) }}
	switch t := d.Next(); t {
	{{- range $cse := $.TypeDiscriminator }}
	case {{ $cse.JXTypes }}:
		{{- with $intType := $cse.IntType }}
		num, err := d.Num()
		if err != nil {
			return errors.Wrap(err, "parse number")
		}
		if d := jx.DecodeBytes(num); num.IsInt() {
			{{- $s := $intType }}
			{{- template "json/dec" elem $s (printf "s.%s" $s.Name) }}
			s.Type = {{ $s.Name }}{{ $.Name }}
		} else {
        	{{- $s = $cse.Type }}
        	{{- template "json/dec" elem $s (printf "s.%s" $s.Name) }}
			s.Type = {{ $s.Name }}{{ $.Name }}
		}
		{{- else }}
			{{- $s := $cse.Type }}
			{{- template "json/dec" elem $s (printf "s.%s" $s.Name) }}
			s.Type = {{ $s.Name }}{{ $.Name }}
		{{- end }}
	{{- end }}
	default:
		return errors.Errorf("unexpected json type %q", t)
	}
	{{- else if or ($d.Fields) ($d.Discriminator) }}
	if typ := d.Next(); typ != jx.Object {
		return errors.Errorf("unexpected json type %q", typ)
	}

	var found bool
	if err := d.Capture(func(d *jx.Decoder) error {
		return d.ObjBytes(func(d *jx.Decoder, key []byte) error {
    		{{- if $d.Discriminator -}}
			if found {
				return d.Skip()
			}
			{{- end }}
			switch string(key) {
			{{- if $d.Discriminator -}}
			case {{ quote $.SumSpec.Discriminator }}:
				typ, err := d.Str()
				if err != nil {
					return err
				}

				// Create a mapping from discriminator value to type
				found = true
				// Set type directly from string value
				s.Type = {{ $.Name }}Type(typ)

				// Initialize the appropriate struct based on the type
				switch s.Type {
				{{- range $s := $.SumOf }}
				{{- $values := $.SumSpec.GetAllDiscriminatorValues $s }}
				{{- if gt (len $values) 0 }}
				{{- range $key := $values }}
				{{- $mapValue := $.SumSpec.GetMapValue $s $key }}
				case {{ $.Name }}{{ $mapValue.FormattedName }}:
					s.{{ $s.Name }} = {{ $s.Go }}{}
				{{- end }}
				{{- else }}
				case {{ $s.Name }}{{ $.Name }}:
					s.{{ $s.Name }} = {{ $s.Go }}{}
				{{- end }}
				{{- end }}
				default:
					return errors.Errorf("unknown type %s", typ)
				}
				return nil
			{{- else }}
			{{- range $s := $.SumOf }}
			{{- range $f := $s.SumSpec.Unique }}
			case {{ quote $f.Tag.JSON }}:
				match := {{ $s.Name }}{{ $.Name }}
				if found && s.Type != match {
					s.Type = ""
					return errors.Errorf("multiple oneOf matches: (%v, %v)", s.Type, match)
				}
				found = true
				s.Type = match
			{{- end }}
			{{- end }}
			{{- end }}
			}
			return d.Skip()
		})
	}); err != nil {
		return errors.Wrap(err, "capture")
	}
	if !found {
		{{- if $.SumSpec.DefaultMapping }}
		{{- range $s := $.SumOf }}
		{{- if eq $s.Name $.SumSpec.DefaultMapping }}
		{{- $values := $.SumSpec.GetAllDiscriminatorValues $s }}
		{{- if gt (len $values) 0 }}
		{{- $mapValue := $.SumSpec.GetMapValue $s (index $values 0) }}
		s.Type = {{ $.Name }}{{ $mapValue.FormattedName }}
		{{- else }}
		s.Type = {{ $s.Name }}{{ $.Name }}
		{{- end }}
		{{- end }}
		{{- end }}
		{{- else }}
		return errors.New("unable to detect sum type variant")
		{{- end }}
	}

	if false {
		// Just a placeholder for first condition
	{{- range $s := $.SumOf }}
	} else if s.Is{{ $s.Name }}() {
		{{- template "json/dec" elem $s (printf "s.%s" $s.Name) }}
	{{- end }}
	} else {
		return errors.Errorf("inferred invalid type: %s", s.Type)
	}
	{{- end }}
	return nil
}

{{ end }}
